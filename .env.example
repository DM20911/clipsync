# ClipSync — environment variables
# Copy to .env and edit, or export in your shell.

# ── Hub ──────────────────────────────────────────────
# WSS port (devices connect here)
CLIPSYNC_PORT_WSS=5678
# HTTPS port (admin dashboard + PWA)
CLIPSYNC_PORT_HTTP=5679
# Bind host (0.0.0.0 = all interfaces; 127.0.0.1 = localhost only)
CLIPSYNC_HOST=0.0.0.0
# Where the SQLite database, TLS certs, and logs live
CLIPSYNC_DATA_DIR=
# History retention
CLIPSYNC_HISTORY_MAX=50
CLIPSYNC_HISTORY_TTL_MS=86400000
# Display name announced via mDNS (defaults to hostname)
CLIPSYNC_HUB_NAME=

# ── Desktop client ──────────────────────────────────
# Where the device's JWT, network key, and config are stored
CLIPSYNC_CLIENT_DIR=
# Clipboard polling interval (ms) — lower = lower latency, higher CPU
CLIPSYNC_POLL_MS=300
